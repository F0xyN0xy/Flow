<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Flow.App.Views.OverlayWindow"
        Title="Flow Overlay"
        Width="400"
        Height="200"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False">

  <Panel Cursor="SizeAll">
    <Border Background="#CC1E1E1E"
            CornerRadius="12"
            BorderBrush="#FF6B35"
            BorderThickness="2"
            Padding="16">
      <StackPanel Spacing="8">
        <TextBlock Text="Flow Overlay"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="White" />
        <TextBlock x:Name="StatusTextBlock"
                   Text="Waiting for Rocket League..."
                   FontSize="12"
                   Foreground="#AAAAAA" />
      </StackPanel>
    </Border>
  </Panel>
</Window>